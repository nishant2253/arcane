{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir":       "dist",
    "rootDir":      "../..",
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@tradeagent/shared": ["../../packages/shared/src"],
      "@tradeagent/hedera": ["../../packages/hedera/src"]
    }
  },
  "include": [
    "src/**/*",
    "../../packages/shared/src/**/*",
    "../../packages/hedera/src/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
